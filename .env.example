# Copy this file to .env (which is gitignored) and fill in your values.
# Paper-trading keys from https://app.alpaca.markets -> "API Keys" (free).
# NEVER commit the real .env or paste keys into chats/issues.

ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
# Paper endpoint -- this project never touches live trading.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Tiingo (https://www.tiingo.com) -- survivorship-bias-free EOD prices incl.
# delisted names; used by quantlab.tiingo_data for H1's price leg.
TIINGO_API_KEY=

# Financial Modeling Prep (https://financialmodelingprep.com) -- optional
# fundamentals cross-check; 5yr annual history caps it below the N=12 DSR hurdle.
FMP_API_KEY=
