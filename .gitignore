# Virtual environments
.venv/
venv/
env/

# Python
__pycache__/
*.pyc
.pytest_cache/
pytest-cache-files-*/
# workspace-local TMP redirect used by sandboxed test runs
.pytest_tmp/

# Data caches (regenerable; never commit market data)
data_cache/

# Secrets -- the real .env never enters git (.env.example documents the keys)
.env

# Scratch outputs (the canonical results/ directory IS committed --
# small PNGs/JSONs regenerable from config + seed, shown in the README)
results_baseline/
results/results/

# Ad-hoc exploration dumps (raw API responses, source samples) — never committed
scratch/
# Adversarial-review / refutation probes (the H1 FF factor CSV the harness reads
# lives in the PARENT folder's scratch_refute via ../../, NOT here, so ignoring the
# repo-local one is safe and keeps review probes out of commits)
scratch_refute/

# Machine-local Claude Code settings
.claude/settings.local.json

# Editor/workspace cruft (Obsidian vault config, etc.)
.obsidian/

# never commit cache archives / vendor data dumps
data_cache.zip
*.zip
