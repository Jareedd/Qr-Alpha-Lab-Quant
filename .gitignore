# Virtual environments
.venv/
venv/
env/

# Python
__pycache__/
*.pyc
.pytest_cache/
pytest-cache-files-*/
# workspace-local TMP redirect used by sandboxed test runs
.pytest_tmp/

# Data caches (regenerable; never commit market data)
data_cache/

# Secrets -- the real .env never enters git (.env.example documents the keys)
.env

# Scratch outputs (the canonical results/ directory IS committed --
# small PNGs/JSONs regenerable from config + seed, shown in the README)
results_baseline/
results/results/

# Ad-hoc exploration dumps (raw API responses, source samples) — never committed
scratch/

# Machine-local Claude Code settings
.claude/settings.local.json
